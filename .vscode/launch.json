{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/vscode-screen-sketch"
            ],
            "outFiles": [
                "${workspaceFolder}/vscode-screen-sketch/out/**/*.js"
            ],
            "preLaunchTask": "ext: compile"
        }
    ]
}